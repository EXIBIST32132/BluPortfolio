# Sanity public project configuration.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-03

# Server-only token for draft preview / Visual Editing reads.
# Use a Sanity Viewer token. Do not expose this to the browser.
SANITY_API_READ_TOKEN=

# Shared secret for the Sanity webhook that calls /api/revalidate.
SANITY_REVALIDATE_SECRET=

# Public deployed URL, used by Sanity Presentation previews.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
